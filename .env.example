# ── Root env consumed by docker-compose ──────────────────────────────
# Copy to .env before running `docker compose up`.

# Postgres
POSTGRES_USER=linkly
POSTGRES_PASSWORD=linkly_dev_password
POSTGRES_DB=linkly

# Backend
# Async driver for SQLAlchemy; host `db` is the compose service name.
DATABASE_URL=postgresql+asyncpg://linkly:linkly_dev_password@db:5432/linkly
REDIS_URL=redis://cache:6379/0
# Base URL used when returning short links to clients.
BASE_URL=http://localhost:8000
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000

# Frontend (Next.js) — exposed to the browser, so no secrets here.
NEXT_PUBLIC_API_URL=http://localhost:8000
