# Backend env for running locally (outside Docker).
DATABASE_URL=postgresql+asyncpg://linkly:linkly_dev_password@localhost:5432/linkly
REDIS_URL=redis://localhost:6379/0
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Redis cache TTL for code -> url lookups (seconds).
CACHE_TTL_SECONDS=3600

# Rate limits (fixed-window, per client IP, per minute).
RATE_LIMIT_CREATE_PER_MINUTE=30
RATE_LIMIT_REDIRECT_PER_MINUTE=600
